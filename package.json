{
  "name": "@cafercangundogdu/nestjs-zod-openapi",
  "version": "0.0.3",
  "description": "NestJS + Zod 4 + OpenAPI — type-safe DTOs with discriminatedUnion oneOf support",
  "author": "Cafer Can Gundogdu",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "typesVersions": {
    "*": {}
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepublishOnly": "pnpm run build",
    "prepare": "husky"
  },
  "keywords": [
    "nestjs",
    "zod",
    "openapi",
    "swagger",
    "zod4",
    "discriminatedUnion",
    "oneOf",
    "dto",
    "validation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cafercangundogdu/nestjs-zod-openapi.git"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "openapi3-ts": "^4.5.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/testing": "^11.1.17",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "publint": "^0.3.18",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}
